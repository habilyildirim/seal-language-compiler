#
i32 main()
{
    i32 a = 5;
    i32 b = 3;
    i32 c = 0;

    i32 x1 = -(-(-a));
    i32 x2 = !!!!a;
    i32 x3 = (a > b); 
    i32 x4 = (a == b);   
    i32 x5 = !!(a - b); 
    i32 x6 = !(a - 5); 
    i32 x7 = -(a == b); 
    i32 x8 = (a > b) + (b > a); 

    i32 x9 =
        -(
            (a + b)
            ==
            (8)
        );

    i32 x10 =
        !!!!(a - b + c)
        + -(-a)
        + !(c);

    i32 x11 =
        !!(a - b * 2)
        + (a == 5)
        + (b == 3);

    i32 result =
        x1 + x2 + x3 + x4 + x5 +
