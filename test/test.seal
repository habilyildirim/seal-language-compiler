# 
i32 main()
{
    i32 a = 5;
    i32 b = 3;
    i32 c = 0;

    i32 x1 = (a > b) && (b > c);
    i32 x2 = (a < b) || (b > c);
    i32 x3 = !(a == b) && !!c;

    i32 x4 = !(!a && !b);
    i32 x5 = -(a > b) && (c == 0);
    
    i32 x6 = ((a > b) || c) && (a + b == 8);
    i32 x7 = (-5 && 5) || (0 && 10);    
    i32 x8 = !!!(a - 5) || !!(b - 3); 
    
    i32 x9 = (a > b) + (a && b) + !(a || c);
    i32 x10 = (!!a && !!b && !!c) || (!(a == 5) && (b == 3));
    i32 result = x1 + x2 + x3 + x4 + x5 + x6 + x7 + x8 + x9 + x10;

    return result;
}
